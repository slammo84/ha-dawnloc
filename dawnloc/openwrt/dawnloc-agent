get_config() {
  uci -q get "dawnloc.main.$1"
}

json_escape() {
  awk 'BEGIN { ORS="" }
    {
      if (NR > 1) printf "\\n"
      gsub(/\\/, "\\\\")
      gsub(/\"/, "\\\"")
      gsub(/\r/, "\\r")
      printf "%s", $0
    }'
}

band_from_frequency() {
  case "$1" in
    24??) printf '%s' '2.4 GHz' ;;
    5???) printf '%s' '5 GHz' ;;
    6???) printf '%s' '6 GHz' ;;
    *) printf '%s' 'unknown' ;;
  esac
}

collect_access_points() {
  first=1
  printf '['
  for object in $(ubus list 'hostapd.*' 2>/dev/null); do
    status="$(ubus call "$object" get_status 2>/dev/null)" || continue
    bssid="$(printf '%s' "$status" | jsonfilter -e '@.bssid' 2>/dev/null)"
    [ -n "$bssid" ] || continue
    frequency="$(printf '%s' "$status" | jsonfilter -e '@.freq' 2>/dev/null)"
    [ -n "$frequency" ] || frequency="$(printf '%s' "$status" | jsonfilter -e '@.frequency' 2>/dev/null)"
    ssid="$(printf '%s' "$status" | jsonfilter -e '@.ssid' 2>/dev/null)"
    band="$(band_from_frequency "$frequency")"

    [ "$first" -eq 1 ] || printf ','
    first=0
    printf '{"bssid":"%s","hostname":"%s","band":"%s"' \
      "$(printf '%s' "$bssid" | json_escape)" \
      "$(printf '%s' "$node_name" | json_escape)" \
      "$(printf '%s' "$band" | json_escape)"
    case "$frequency" in
      ''|*[!0-9]*) ;;
      *) printf ',"frequency":%s' "$frequency" ;;
    esac
    if [ -n "$ssid" ]; then
      printf ',"ssid":"%s"' "$(printf '%s' "$ssid" | json_escape)"
    fi
    printf '}'
  done
  printf ']'
}

collect_uci_clients() {
  [ -r /lib/functions.sh ] || return 0

  (
    . /lib/functions.sh

    static_name=""
    static_ip=""

    emit_static_mac() {
      local mac="$1"
      [ -n "$mac" ] || return 0
      mac="$(printf '%s' "$mac" | tr 'A-F' 'a-f')"
      printf '%s\t%s\t%s\t20\n' "$mac" "$static_ip" "$static_name"
    }

    collect_static_host() {
      local section="$1"
      local macs=""

      static_name=""
      static_ip=""
      config_get static_name "$section" name
      config_get static_ip "$section" ip
      config_get macs "$section" mac

      for mac in $macs; do
        emit_static_mac "$mac"
      done
      config_list_foreach "$section" mac emit_static_mac
    }

    config_load dhcp
    config_foreach collect_static_host host
  )
}

collect_clients() {
  {
    collect_uci_clients

    if [ -r /tmp/dhcp.leases ]; then
      awk '
        NF >= 4 {
          mac=tolower($2); ip=$3; host=$4
          if (host == "*") host=""
          gsub(/[\t\r\n]/, "", host)
          print mac "\t" ip "\t" host "\t30"
        }
      ' /tmp/dhcp.leases
    fi

    ip neigh show 2>/dev/null | awk '
      {
        ip=$1; mac=""
        if (index(ip, ":") > 0) next
        for (i=1; i<=NF; i++) {
          if ($i == "lladdr" && (i + 1) <= NF) {
            mac=tolower($(i + 1))
            break
          }
        }
        if (mac != "") print mac "\t" ip "\t\t10"
      }
    '
  } | awk -F '\t' '
    function valid_mac(value) {
      return value ~ /^([0-9a-f][0-9a-f]:){5}[0-9a-f][0-9a-f]$/
    }
    function esc(value) {
      gsub(/\\/, "\\\\", value)
      gsub(/\"/, "\\\"", value)
      return value
    }
    {
      mac=tolower($1); ip=$2; host=$3; priority=$4 + 0
      if (!valid_mac(mac)) next
      seen[mac]=1
      if (ip != "" && priority >= ip_priority[mac]) {
        addresses[mac]=ip
        ip_priority[mac]=priority
      }
      if (host != "" && host != "*" && priority >= host_priority[mac]) {
        hostnames[mac]=host
        host_priority[mac]=priority
      }
    }
    END {
      printf "["
      first=1
      for (mac in seen) {
        if (!first) printf ","
        first=0
        printf "{\"mac\":\"%s\"", esc(mac)
        if (addresses[mac] != "") printf ",\"ip\":\"%s\"", esc(addresses[mac])
        if (hostnames[mac] != "") printf ",\"hostname\":\"%s\"", esc(hostnames[mac])
        printf "}"
      }
      printf "]"
    }
  '
}

publish_payload() {
  if [ "$tls" = "1" ]; then
    if [ -n "$username" ]; then
      mosquitto_pub \
        -h "$broker" -p "$port" \
        -u "$username" -P "$password" \
        --capath /etc/ssl/certs \
        -t "$topic" -s
    else
      mosquitto_pub \
        -h "$broker" -p "$port" \
        --capath /etc/ssl/certs \
        -t "$topic" -s
    fi
  elif [ -n "$username" ]; then
    mosquitto_pub \
      -h "$broker" -p "$port" \
      -u "$username" -P "$password" \
      -t "$topic" -s
  else
    mosquitto_pub -h "$broker" -p "$port" -t "$topic" -s
  fi
}

enabled="$(get_config enabled)"
[ "$enabled" = "1" ] || exit 0

broker="$(get_config broker)"
port="$(get_config port)"
username="$(get_config username)"
password="$(get_config password)"
topic="$(get_config topic)"
interval="$(get_config interval)"
tls="$(get_config tls)"
node_name="$(get_config node_name)"

[ -n "$broker" ] || {
  logger -t dawnloc "MQTT broker is not configured"
  exit 1
}
[ -n "$port" ] || port=1883
[ -n "$topic" ] || topic="dawnloc/raw/hearing_map"
[ -n "$interval" ] || interval=3
[ -n "$tls" ] || tls=0
[ -n "$node_name" ] || node_name="$(uci -q get system.@system[0].hostname)"
[ -n "$node_name" ] || node_name="openwrt"

trap 'exit 0' INT TERM

while true; do
  hearing_map="$(ubus call dawn get_hearing_map 2>/dev/null)"
  if [ -z "$hearing_map" ]; then
    logger -t dawnloc "dawn.get_hearing_map returned no data"
  else
    access_points="$(collect_access_points)"
    clients="$(collect_clients)"
    if ! printf '{"node":"%s","generated_at":%s,"hearing_map":%s,"access_points":%s,"clients":%s}' \
      "$(printf '%s' "$node_name" | json_escape)" \
      "$(date +%s)" \
      "$hearing_map" \
      "$access_points" \
      "$clients" | publish_payload; then
      logger -t dawnloc "failed to publish hearing map"
    fi
  fi
  sleep "$interval" &
  wait $!
done
